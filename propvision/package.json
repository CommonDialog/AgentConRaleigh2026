{
  "name": "propvision",
  "private": true,
  "version": "0.1.0",
  "description": "AI Architectural & Real Estate Visualization Platform",
  "workspaces": ["server", "client"],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "test": "npm --workspace server test"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
