generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ARCHITECT
  AGENT
  ADMIN
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum ProjectType {
  STAGING
  DECLUTTER
  ENVIRONMENTAL_EDIT
  SKETCH_RENDER
  SPACE_OPTIMIZATION
  RESIZE
}

enum ProjectStatus {
  DRAFT
  PROCESSING
  COMPLETE
  FAILED
}

enum AssetType {
  SOURCE_IMAGE
  GENERATED_IMAGE
  FLOOR_PLAN
  DEPTH_MAP
  SKETCH
  MASK
}

enum JobStatus {
  QUEUED
  PROCESSING
  STREAMING
  COMPLETE
  FAILED
  CANCELLED
}

enum CreditTransactionType {
  PURCHASE
  CONSUMPTION
  REFUND
  BONUS
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String
  name             String
  role             UserRole         @default(AGENT)
  subscriptionTier SubscriptionTier @default(FREE)
  creditsBalance   Int              @default(0)
  stripeCustomerId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  projects     Project[]
  jobs         Job[]
  transactions CreditTransaction[]

  @@index([email])
}

model Project {
  id          String        @id @default(uuid())
  userId      String
  name        String
  description String?
  type        ProjectType
  status      ProjectStatus @default(DRAFT)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets Asset[]
  jobs   Job[]

  @@index([userId])
}

model Asset {
  id            String    @id @default(uuid())
  projectId     String
  type          AssetType
  storageUrl    String
  thumbnailUrl  String?
  mimeType      String
  width         Int?
  height        Int?
  fileSizeBytes Int?
  metadata      Json?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Job {
  id           String      @id @default(uuid())
  projectId    String
  userId       String
  type         ProjectType
  status       JobStatus   @default(QUEUED)
  priority     Int         @default(0)
  creditsCost  Int
  params       Json
  result       Json?
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@index([status])
  @@index([userId])
  @@index([projectId])
}

model CreditTransaction {
  id                    String                @id @default(uuid())
  userId                String
  amount                Int
  type                  CreditTransactionType
  jobId                 String?
  stripePaymentIntentId String?
  description           String
  createdAt             DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
}
